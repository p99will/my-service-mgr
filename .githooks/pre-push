#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

current_version="$(python3 - <<'PY'
from pathlib import Path
import re
text = Path("pyproject.toml").read_text(encoding="utf-8")
match = re.search(r'^version = "([^"]+)"$', text, re.MULTILINE)
if not match:
    raise SystemExit(1)
print(match.group(1))
PY
)"

if ! git tag --points-at HEAD | grep -qx "v${current_version}"; then
  echo "pre-push: warning: HEAD is missing tag v${current_version}. Ensure .githooks is configured and commit again if needed." >&2
fi

if [[ "$(git config --get push.followTags || true)" != "true" ]]; then
  echo "pre-push: warning: push.followTags is not enabled, so tags may not be pushed automatically." >&2
fi
