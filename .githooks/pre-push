#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

current_version="$(python3 - <<'PY'
from pathlib import Path
import re
text = Path("pyproject.toml").read_text(encoding="utf-8")
match = re.search(r'^version = "([^"]+)"$', text, re.MULTILINE)
if not match:
    raise SystemExit(1)
print(match.group(1))
PY
)"

if git tag --points-at HEAD | grep -qx "v${current_version}"; then
  exit 0
fi

if [[ -n "$(git status --short)" ]]; then
  echo "pre-push: worktree must be clean before automatic version bumping." >&2
  exit 1
fi

python3 scripts/bump_version.py

echo "pre-push: version bumped and tag created. Run 'git push --follow-tags' again to push the new commit and tag." >&2
exit 1
